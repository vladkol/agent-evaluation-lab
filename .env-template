GOOGLE_GENAI_USE_VERTEXAI="true"
GOOGLE_CLOUD_PROJECT=""           # Cloud project to use
GOOGLE_CLOUD_LOCATION="global"    # Cloud location to use with Gemini API
GOOGLE_CLOUD_REGION="us-central1" # Region to deploy Cloud Run services to

# LOCAL_EVAL="true" # Uncomment to force local/offline evaluation

# Uncomment if evaluating agents that run locally
# (`./run_local.sh`` and `uv run -m evaluator.evaluate_agent`)
# RESEARCHER_URL="http://localhost:8001"
# ORCHESTRATOR_URL="http://localhost:8004"
